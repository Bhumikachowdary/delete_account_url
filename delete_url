<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Delete Account - DiaSafe</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f4f6f9;
      margin: 0;
      padding: 0;
    }

    .container {
      max-width: 600px;
      margin: 60px auto;
      background: white;
      padding: 30px;
      border-radius: 12px;
      box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    h1 {
      text-align: center;
      color: #e53935;
    }

    p {
      font-size: 16px;
      color: #444;
      line-height: 1.6;
    }

    .warning {
      background: #fff3f3;
      border-left: 5px solid red;
      padding: 10px;
      margin: 20px 0;
    }

    input {
      width: 100%;
      padding: 12px;
      margin-top: 10px;
      border-radius: 6px;
      border: 1px solid #ccc;
      font-size: 14px;
    }

    button {
      width: 100%;
      padding: 12px;
      margin-top: 20px;
      background: #e53935;
      color: white;
      border: none;
      border-radius: 6px;
      font-size: 16px;
      cursor: pointer;
    }

    button:hover {
      background: #c62828;
    }

    .success {
      color: green;
      text-align: center;
      margin-top: 20px;
      display: none;
    }
  </style>
</head>

<body>

<div class="container">
  <h1>Delete Your Account</h1>

  <p>
    We're sorry to see you go. If you wish to delete your DiaSafe account,
    please enter your registered email below and confirm.
  </p>

  <div class="warning">
    ⚠️ <strong>Warning:</strong> This action is permanent. All your data,
    reports, and history will be deleted and cannot be recovered.
  </div>

  <label>Email Address</label>
  <input type="email" id="email" placeholder="Enter your email" required>

  <button onclick="deleteAccount()">Delete My Account</button>

  <p class="success" id="successMsg">
    ✅ Your deletion request has been submitted successfully.
  </p>
</div>

<script>
  function deleteAccount() {
    const email = document.getElementById("email").value;

    if (!email) {
      alert("Please enter your email");
      return;
    }

    // 🔥 Replace this with your backend API
    fetch("https://your-backend-url/api/delete-account/", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({ email: email })
    })
    .then(response => {
      if (response.ok) {
        document.getElementById("successMsg").style.display = "block";
      } else {
        alert("Something went wrong");
      }
    })
    .catch(error => {
      alert("Error connecting to server");
    });
  }
</script>

</body>
</html>
